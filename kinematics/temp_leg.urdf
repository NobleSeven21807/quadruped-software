<?xml version="1.0"?>
<robot name="simple_leg">
  <link name="base_link">
    <visual><geometry><box size="0.1 0.1 0.1"/></geometry><material name="blue"><color rgba="0 0 1 1"/></material></visual>
  </link>

  <link name="coxa">
    <visual><geometry><cylinder length="0.05" radius="0.02"/></geometry>
    <origin rpy="1.5708 0 0" xyz="0 0.025 0"/></visual>
  </link>

  <link name="femur">
    <visual><geometry><cylinder length="0.2" radius="0.02"/></geometry>
    <origin rpy="0 0 0" xyz="0 0 -0.1"/></visual>
  </link>

  <link name="tibia">
    <visual><geometry><cylinder length="0.2" radius="0.015"/></geometry>
    <origin rpy="0 0 0" xyz="0 0 -0.1"/></visual>
  </link>

  <joint name="shoulder_roll" type="revolute">
    <parent link="base_link"/><child link="coxa"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/> <limit effort="10" velocity="10" lower="-1.5" upper="1.5"/>
  </joint>

  <joint name="shoulder_pitch" type="revolute">
    <parent link="coxa"/><child link="femur"/>
    <origin xyz="0 0.05 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/> <limit effort="10" velocity="10" lower="-1.5" upper="1.5"/>
  </joint>

  <joint name="knee_pitch" type="revolute">
    <parent link="femur"/><child link="tibia"/>
    <origin xyz="0 0 -0.2" rpy="0 0 0"/>
    <axis xyz="0 1 0"/> <limit effort="10" velocity="10" lower="-3.0" upper="3.0"/>
  </joint>
</robot>
