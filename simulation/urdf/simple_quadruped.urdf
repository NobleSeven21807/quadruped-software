<?xml version="1.0"?>
<robot name="simple_quadruped">

  <!-- ================== Body ================== -->
  <link name="base">
    <visual>
      <geometry>
        <box size="0.4 0.2 0.05"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.4 0.2 0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01"/>
      <origin xyz="0 0 0"/>
    </inertial>
  </link>

  <!-- ================== Legs ================== -->
  <!-- We'll repeat this pattern for 4 legs -->
  <!-- Leg positions: front-right, front-left, rear-right, rear-left -->

  <!-- ---------- Front Right Leg ---------- -->
  <link name="FR_upper_leg">
    <visual>
      <geometry>
        <cylinder radius="0.02" length="0.2"/>
      </geometry>
      <origin xyz="0 0 -0.1" rpy="0 0 0"/>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.02" length="0.2"/>
      </geometry>
      <origin xyz="0 0 -0.1"/>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001"/>
      <origin xyz="0 0 -0.1"/>
    </inertial>
  </link>

  <joint name="FR_hip_abduction" type="revolute">
    <parent link="base"/>
    <child link="FR_upper_leg"/>
    <origin xyz="0.15 -0.1 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/> <!-- lateral movement -->
    <limit lower="-1.0" upper="1.0" effort="5" velocity="2"/>
  </joint>

  <link name="FR_lower_leg">
    <visual>
      <geometry>
        <cylinder radius="0.015" length="0.2"/>
      </geometry>
      <origin xyz="0 0 -0.1"/>
      <material name="green"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.015" length="0.2"/>
      </geometry>
      <origin xyz="0 0 -0.1"/>
    </collision>
    <inertial>
      <mass value="0.08"/>
      <inertia ixx="0.0008" iyy="0.0008" izz="0.0008"/>
      <origin xyz="0 0 -0.1"/>
    </inertial>
  </link>

  <joint name="FR_hip_flexion" type="revolute">
    <parent link="FR_upper_leg"/>
    <child link="FR_lower_leg"/>
    <origin xyz="0 0 -0.2" rpy="0 0 0"/>
    <axis xyz="1 0 0"/> <!-- forward/backward swing -->
    <limit lower="-1.5" upper="1.5" effort="5" velocity="2"/>
  </joint>

  <link name="FR_foot">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0005" iyy="0.0005" izz="0.0005"/>
    </inertial>
  </link>

  <joint name="FR_knee_flexion" type="revolute">
    <parent link="FR_lower_leg"/>
    <child link="FR_foot"/>
    <origin xyz="0 0 -0.2"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="2.0" effort="5" velocity="2"/>
  </joint>

  <!-- ---------- Front Left Leg ---------- -->
  <!-- Copy the same structure, just adjust hip origin -->
  <link name="FL_upper_leg">
    <visual>
      <geometry>
        <cylinder radius="0.02" length="0.2"/>
      </geometry>
      <origin xyz="0 0 -0.1"/>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.02" length="0.2"/>
      </geometry>
      <origin xyz="0 0 -0.1"/>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001"/>
      <origin xyz="0 0 -0.1"/>
    </inertial>
  </link>

  <joint name="FL_hip_abduction" type="revolute">
    <parent link="base"/>
    <child link="FL_upper_leg"/>
    <origin xyz="0.15 0.1 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.0" upper="1.0" effort="5" velocity="2"/>
  </joint>

  <link name="FL_lower_leg">
    <visual>
      <geometry>
        <cylinder radius="0.015" length="0.2"/>
      </geometry>
      <origin xyz="0 0 -0.1"/>
      <material name="green"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.015" length="0.2"/>
      </geometry>
      <origin xyz="0 0 -0.1"/>
    </collision>
    <inertial>
      <mass value="0.08"/>
      <inertia ixx="0.0008" iyy="0.0008" izz="0.0008"/>
      <origin xyz="0 0 -0.1"/>
    </inertial>
  </link>

  <joint name="FL_hip_flexion" type="revolute">
    <parent link="FL_upper_leg"/>
    <child link="FL_lower_leg"/>
    <origin xyz="0 0 -0.2"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.5" upper="1.5" effort="5" velocity="2"/>
  </joint>

  <link name="FL_foot">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0005" iyy="0.0005" izz="0.0005"/>
    </inertial>
  </link>

  <joint name="FL_knee_flexion" type="revolute">
    <parent link="FL_lower_leg"/>
    <child link="FL_foot"/>
    <origin xyz="0 0 -0.2"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="2.0" effort="5" velocity="2"/>
  </joint>

  <!-- ---------- Rear Right Leg ---------- -->
  <!-- Repeat same pattern, adjust hip origin -->
  <link name="RR_upper_leg">
    <visual>
      <geometry>
        <cylinder radius="0.02" length="0.2"/>
      </geometry>
      <origin xyz="0 0 -0.1"/>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.02" length="0.2"/>
      </geometry>
      <origin xyz="0 0 -0.1"/>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001"/>
      <origin xyz="0 0 -0.1"/>
    </inertial>
  </link>

  <joint name="RR_hip_abduction" type="revolute">
    <parent link="base"/>
    <child link="RR_upper_leg"/>
    <origin xyz="-0.15 -0.1 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.0" upper="1.0" effort="5" velocity="2"/>
  </joint>

  <link name="RR_lower_leg">
    <visual>
      <geometry>
        <cylinder radius="0.015" length="0.2"/>
      </geometry>
      <origin xyz="0 0 -0.1"/>
      <material name="green"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.015" length="0.2"/>
      </geometry>
      <origin xyz="0 0 -0.1"/>
    </collision>
    <inertial>
      <mass value="0.08"/>
      <inertia ixx="0.0008" iyy="0.0008" izz="0.0008"/>
      <origin xyz="0 0 -0.1"/>
    </inertial>
  </link>

  <joint name="RR_hip_flexion" type="revolute">
    <parent link="RR_upper_leg"/>
    <child link="RR_lower_leg"/>
    <origin xyz="0 0 -0.2"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.5" upper="1.5" effort="5" velocity="2"/>
  </joint>

  <link name="RR_foot">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0005" iyy="0.0005" izz="0.0005"/>
    </inertial>
  </link>

  <joint name="RR_knee_flexion" type="revolute">
    <parent link="RR_lower_leg"/>
    <child link="RR_foot"/>
    <origin xyz="0 0 -0.2"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="2.0" effort="5" velocity="2"/>
  </joint>

  <!-- ---------- Rear Left Leg ---------- -->
  <link name="RL_upper_leg">
    <visual>
      <geometry>
        <cylinder radius="0.02" length="0.2"/>
      </geometry>
      <origin xyz="0 0 -0.1"/>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.02" length="0.2"/>
      </geometry>
      <origin xyz="0 0 -0.1"/>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001"/>
      <origin xyz="0 0 -0.1"/>
    </inertial>
  </link>

  <joint name="RL_hip_abduction" type="revolute">
    <parent link="base"/>
    <child link="RL_upper_leg"/>
    <origin xyz="-0.15 0.1 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.0" upper="1.0" effort="5" velocity="2"/>
  </joint>

  <link name="RL_lower_leg">
    <visual>
      <geometry>
        <cylinder radius="0.015" length="0.2"/>
      </geometry>
