    </collision>
    <inertial>
      <mass value="0.08"/>
      <inertia ixx="0.0008" iyy="0.0008" izz="0.0008"/>
      <origin xyz="0 0 -0.1"/>
    </inertial>
  </link>

  <joint name="RL_hip_flexion" type="revolute">
    <parent link="RL_upper_leg"/>
    <child link="RL_lower_leg"/>
    <origin xyz="0 0 -0.2"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.5" upper="1.5" effort="5" velocity="2"/>
